# Single top-level .gitignore for both subprojects (toy/, planning/).

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
.claude/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
env/
.env

# Jupyter
.ipynb_checkpoints/

# PyTorch / ML artifacts
*.pt
*.pth
*.ckpt
checkpoints/
runs/
wandb/
lightning_logs/

# Datasets (downloaded or generated locally; see planning/README.md)
*.h5
*.hdf5
*.npz
*.npy
planning/data/*
!planning/data/external/
planning/data/external/*
!planning/data/external/.gitkeep
!planning/data/generated/
planning/data/generated/*
!planning/data/generated/.gitkeep

# Experiment outputs (regenerated by run.sh / notebooks)
results/
outputs/
experiments/**/results/
experiments/**/outputs/

# Caches
.cache/
.cluster-cache/
.mplconfig/

# Cluster job logs (the *.sub submit files are tracked)
condor.*
*.out
*.log
*.err
